# Copy to .env.local and fill from the handover (.env from the previous build).
# Everything below is read at build time via NEXT_PUBLIC_* — restart `next dev`
# after changing values. Widgets/scripts are gated on their var being set, so a
# blank value simply disables that integration (no errors).

# Analytics already live on the current site — reuse these.
# NOTE: GA4 may already fire INSIDE the GTM container. If it does, leave
# NEXT_PUBLIC_GA_ID blank so GTM owns GA and you don't double-count pageviews.
NEXT_PUBLIC_GA_ID=G-0SW8NFFFEV
NEXT_PUBLIC_GTM_ID=GTM-KRJHXP6D

# Meta Pixel — NOT configured on the current site. Get the real ID to activate,
# or leave blank to keep it disabled (drop).
NEXT_PUBLIC_FB_PIXEL_ID=

# Elfsight widgets (one account holds all three). The widgets only render for
# the account that owns these app IDs — request the Elfsight login.
NEXT_PUBLIC_ELFSIGHT_REVIEWS_ID=d1917f6b-3683-47c5-b84b-86ba2c12f365
NEXT_PUBLIC_ELFSIGHT_INSTAGRAM_ID=515ff663-a805-49e8-a69f-7352c2057bab
NEXT_PUBLIC_ELFSIGHT_ABOUT_ID=8a247cda-f474-4a67-aca0-394bedb7584e

# Contact / social
NEXT_PUBLIC_WHATSAPP=50684319953

# SiteMinder booking engine (NEW — get from the SiteMinder account)
NEXT_PUBLIC_SITEMINDER_PROPERTY_ID=

# Resend — powers the experience/event inquiry forms (/api/inquiry).
# Until ALL of these are set AND a sending domain is verified in Resend, the
# forms silently fall back to WhatsApp/email (no error shown to guests).
#   1. Create a Resend account, add + verify your domain (DNS records).
#   2. Create an API key -> RESEND_API_KEY.
#   3. Set INQUIRY_FROM_EMAIL to an address on the verified domain, e.g.
#      "Terraza del Pacífico <eventos@terrazadelpacifico.com>".
# INQUIRY_TO_EMAIL defaults to mercadeo1@terrazadelpacifico.com if unset.
RESEND_API_KEY=
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=
